+        };
+
+        SP<Render::IFramebuffer> m_monitorMirrorFB;
+        WP<CMonitor>             m_monitor;
+        DRMFormat                m_drmFormat;
+        Vector2D                 m_size;
+
+        std::vector<SResource>   m_workBuffers;
+
+        friend class ::CMonitor;
+    };
+}
